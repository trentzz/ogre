@fn not {
    >+<[>-<[-]]>[<+>-]<
}

@fn bool {
    [[-]>+<]>[<+>-]<
}

@fn and {
    >[-]<
    [>+<[-]]
    >[<+>-]<
}

@fn or {
    >[<+>-]<
    [[-]>+<]>[<+>-]<
}

@fn equal {
    >>[-]<<<
    [>>>+<<<-]
    >[>>>+<<<-]<
    >>>
    [<->-]<
    >+<
    [>-<[-]]>
    [<<<<+>>>>-]<
    [-]
    <<<
}
