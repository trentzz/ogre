@doc Skip a leading -- prefix by reading and discarding 2 characters
@fn skip_dashes {
    ,,[-]
}

@doc Read characters until a space (32) is found. Space consumed. Cell 0 cleared.
@doc Uses cell 1 as scratch.
@fn skip_to_space {
    ,
    >++++++++++++++++++++++++++++++++<
    [>-<-]>
    [<+>-]<
    [
        [-],
        >++++++++++++++++++++++++++++++++<
        [>-<-]>
        [<+>-]<
    ]
    [-]
}

@doc Read characters until a newline (10) is found. Newline consumed. Cell 0 cleared.
@doc Uses cell 1 as scratch.
@fn skip_to_newline {
    ,
    >++++++++++<
    [>-<-]>
    [<+>-]<
    [
        [-],
        >++++++++++<
        [>-<-]>
        [<+>-]<
    ]
    [-]
}

@doc Read characters until space (32) or EOF (0), storing starting at cell 0.
@doc Each char occupies one cell going right. Pointer ends at the zero terminator cell.
@doc The terminating space is not stored.
@fn read_arg {
    ,
    --------------------------------
    [
        ++++++++++++++++++++++++++++++++
        >
        ,
        --------------------------------
    ]
}

@doc Skip -- prefix, read the next char as a flag identifier into cell 0, then skip to next space.
@doc Cell 0 will contain the flag character. Uses cells 1-2 as scratch.
@fn read_flag_char {
    ,,
    ,
    >,
    >++++++++++++++++++++++++++++++++<
    [>-<-]>
    [<+>-]<
    [
        [-],
        >++++++++++++++++++++++++++++++++<
        [>-<-]>
        [<+>-]<
    ]
    [-]<
}

@doc Print the string "Error: " to output
@fn print_error_prefix {
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++.[-]
}

@doc Print the string "Usage: " to output
@fn print_usage_prefix {
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++++++++++++++++++++++++.[-]
}

@doc Compare cell 0 against cell 1. Set cell 2 to 1 if equal, 0 if not.
@doc Cell 0 preserved, cell 1 zeroed. Uses cell 3 as scratch.
@fn match_char {
    [>>+>+<<<-]>>>[<<<+>>>-]<<<
    >[>-<-]<
    >>
    >+<
    [>-<[-]]>
    [<+>-]<
    <<
}
