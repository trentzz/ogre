@doc Set cell 1 to 1 if cell 0 is a digit (48 to 57). Uses cells 1 to 3.
@fn is_digit {
    [>+>+<<-]>>[<<+>>-]<<
    >
    ------------------------------------------------
    ++++++++++
    [>+>+<<-]>>[<<+>>-]<
    [<->-]<
    [[-]>-<]>
    [<+>-]<
    <
    >>[<<+>>-]<<
    >[-]>[-]<
    <[>+<-]>[->>+<<]>>[-<+<+>>]<<
    >[-]>[-]<
    <
}

@doc Set cell 1 to 1 if cell 0 is space (32). Nondestructive.
@fn is_space {
    [>+>+<<-]>>[<<+>>-]<
    --------------------------------
    >+<
    [>-<[-]]>
    [<+>-]<
    <
}

