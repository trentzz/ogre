@fn dump_cell {
    .
}

@fn dump_and_newline {
    .++++++++++.[-]
}

@fn marker_start {
    >++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]<
}

@fn marker_end {
    >+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.[-]<
}

@doc Print cell 0 as a decimal number for debugging, followed by newline. Cell 0 cleared. Uses cells 1-6 as scratch.
@fn dump_decimal {
    >++++++++++<
    [->-[>+>>]>[+[-<+>]>+>>]<<<<<]
    >[-]>[->>>>+<<<<]>[-<<<+>>>]<<<>[-]>[-]>[-]<<<
    >++++++++++<
    [->-[>+>>]>[+[-<+>]>+>>]<<<<<]
    >[-]>[->>>+<<<]>[-<<<+>>>]<<<>[-]>[-]>[-]<<<
    [++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>>>+<<<<]
    >>>>>[-<<<<+>>>>]<<<<<
    >[>+>+<<-]>>[<<+>>-]<
    [[-]>+<]>[<+>-]<
    >>[<<+>>-]<<
    [[-]>+<]>[<+>-]<
    [<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>[-]]
    <[-]<
    >>>>>>++++++++++++++++++++++++++++++++++++++++++++++++.[-]<<<<<<
    [-]>[-]>[-]>[-]>[-]>[-]<<<<<
    ++++++++++.[-]
}

@doc Print cell 0 as 2-digit hex (e.g. 4F). Cell 0 cleared. Uses cells 1-9 as scratch.
@fn dump_hex {
    >++++++++++++++++<
    [->-[>+>>]>[+[-<+>]>+>>]<<<<<]
    >[-]>[->>>>>>+<<<<<<]>[-<<<+>>>]<<<>[-]>[-]>[-]<<<
    [>+>+<<-]>>[<<+>>-]<<
    >>++++++++++<
    [->-[>+>>]>[+[-<+>]>+>>]<<<<<]
    >[-]>[-]<
    >>[<<<<+++++++>>>>[-]]<<<<
    ++++++++++++++++++++++++++++++++++++++++++++++++
    .[-]
    >[-]>[-]>[-]>[-]<<<<
    >>>>>>>>
    [>+>+<<-]>>[<<+>>-]<<
    >>++++++++++<
    [->-[>+>>]>[+[-<+>]>+>>]<<<<<]
    >[-]>[-]<
    >>[<<<<+++++++>>>>[-]]<<<<
    ++++++++++++++++++++++++++++++++++++++++++++++++
    .[-]
    >[-]>[-]>[-]>[-]<<<<
    <<<<<<<<
    [-]>[-]>[-]>[-]>[-]>[-]>[-]>[-]>[-]>[-]>[-]>[-]>[-]<<<<<<<<<<<<
}

@doc Print "---\n" as a debug separator line
@fn separator {
    +++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++.[-]
    +++++++++++++++++++++++++++++++++++++++++++++.[-]
    ++++++++++.[-]
}

@doc Print 5 cells starting from c0 as decimal values separated by spaces.
@doc All 5 cells cleared after. Uses scratch cells after c4.
@fn dump_range_5 {
    [>+<-]>
    [->++++++++++<]>[-<<+>>]<[-<+>]<
    [->++++++++++<]>[-<<+>>]<[->>>+<<<]
    >[->>+<<]>[->>+<<]<<<
    [>+>+<<-]>>[<<+>>-]<
    [<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>-]
    >[<+>-]<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>[-]<<]
    >>[<<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>-]
    <<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]]
    [-]>[-]>[-]>[-]>[-]<<<<<
    ++++++++++++++++++++++++++++++++.[-]

    >[>+<-]>>
    [->++++++++++<]>[-<<+>>]<[-<+>]<
    [->++++++++++<]>[-<<+>>]<[->>>+<<<]
    >[->>+<<]>[->>+<<]<<<
    [>+>+<<-]>>[<<+>>-]<
    [<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>-]
    >[<+>-]<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>[-]<<]
    >>[<<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>-]
    <<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]]
    [-]>[-]>[-]>[-]>[-]<<<<<
    <++++++++++++++++++++++++++++++++.[-]

    >>[>+<-]>>
    [->++++++++++<]>[-<<+>>]<[-<+>]<
    [->++++++++++<]>[-<<+>>]<[->>>+<<<]
    >[->>+<<]>[->>+<<]<<<
    [>+>+<<-]>>[<<+>>-]<
    [<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>-]
    >[<+>-]<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>[-]<<]
    >>[<<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>-]
    <<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]]
    [-]>[-]>[-]>[-]>[-]<<<<<
    <<++++++++++++++++++++++++++++++++.[-]

    >>>[>+<-]>>
    [->++++++++++<]>[-<<+>>]<[-<+>]<
    [->++++++++++<]>[-<<+>>]<[->>>+<<<]
    >[->>+<<]>[->>+<<]<<<
    [>+>+<<-]>>[<<+>>-]<
    [<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>-]
    >[<+>-]<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>[-]<<]
    >>[<<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>-]
    <<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]]
    [-]>[-]>[-]>[-]>[-]<<<<<
    <<<++++++++++++++++++++++++++++++++.[-]

    >>>>[>+<-]>>
    [->++++++++++<]>[-<<+>>]<[-<+>]<
    [->++++++++++<]>[-<<+>>]<[->>>+<<<]
    >[->>+<<]>[->>+<<]<<<
    [>+>+<<-]>>[<<+>>-]<
    [<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>-]
    >[<+>-]<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>[-]<<]
    >>[<<++++++++++++++++++++++++++++++++++++++++++++++++.[-]>>-]
    <<[++++++++++++++++++++++++++++++++++++++++++++++++.[-]]
    [-]>[-]>[-]>[-]>[-]<<<<<
    <<<<++++++++++.[-]
}
